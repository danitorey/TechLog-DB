# ──────────────────────────────────────────────────────────────
#  TechLog DB — Plantilla de variables de entorno
#
#  INSTRUCCIONES:
#  1. Copia este archivo: cp .env.example .env
#  2. Cambia los valores de PASSWORD y USER por los tuyos
#  3. El puerto 5433 puedes cambiarlo si ya esta ocupado
#  4. N8N_ENCRYPTION_KEY debe ser una cadena aleatoria de 32+ chars
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=techlog
POSTGRES_USER=tu_usuario
POSTGRES_PASSWORD=tu_password_seguro
POSTGRES_PORT=5433

# ── n8n ──────────────────────────────────────────────────────
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=tu_password_n8n
N8N_ENCRYPTION_KEY=escribe_aqui_una_clave_aleatoria_larga
WEBHOOK_URL=http://localhost:5678
